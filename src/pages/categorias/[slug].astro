---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import Icon from '@/components/Icon.astro';
import { SITE } from '@/lib/site';
import categories from '@data/categories.json';
import products from '@data/products.json';

export function getStaticPaths() {
  return (categories as any[]).map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const categoryProducts = (products as any[]).filter((p) => p.categoryId === category.id || p.categoryId === category.slug);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: category.seoTitle || category.name,
  description: category.seoDescription || category.description,
  url: `${SITE.url}/categorias/${category.slug}/`,
};
---

<BaseLayout
  title={category.seoTitle || `${category.name} Personalizados con Logo | Colombia`}
  description={category.seoDescription || category.description}
  jsonLd={jsonLd}
>
  <section class="section-navy-deep relative pt-32 pb-16">
    <div class="absolute inset-0 grid-pattern pointer-events-none"></div>
    <div class="container-ks relative z-10">
      <nav class="flex items-center gap-2 text-sm text-white/60 mb-6">
        <a href="/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <a href="/categorias/" class="hover:text-white transition-colors">Categorías</a>
        <span>/</span>
        <span class="text-white font-medium">{category.name}</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-5 max-w-3xl">{category.name}</h1>
      {category.description && <p class="text-white/70 text-lg max-w-2xl">{category.description}</p>}

      {category.benefits?.length > 0 && (
        <div class="flex flex-wrap gap-3 mt-8">
          {category.benefits.map((b: string) => (
            <span class="inline-flex items-center gap-1.5 text-xs font-medium bg-white/10 text-white/90 px-3 py-1.5 rounded-full">
              <Icon name="check-circle" size={13} /> {b}
            </span>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="py-14 lg:py-20">
    <div class="container-ks">
      <p class="text-sm text-gray-500 mb-8">{categoryProducts.length} referencias en esta categoría</p>

      {categoryProducts.length > 0 ? (
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
          {categoryProducts.map((p, i) => (
            <div class={`reveal stagger-${(i % 6) + 1}`} style={`--stagger: ${(i % 6) * 60}ms`}>
              <ProductCard product={p} eager={i < 4} />
            </div>
          ))}
        </div>
      ) : (
        <p class="text-gray-500">Muy pronto sumaremos referencias a esta categoría. Escríbenos por WhatsApp y te ayudamos a encontrar la opción ideal.</p>
      )}
    </div>
  </section>

  {category.editorial && (
    <section class="py-16 bg-ks-navy-ghost">
      <div class="container-ks max-w-3xl">
        <h2 class="font-heading font-bold text-2xl text-[#0A0A23] mb-4">Sobre {category.name.toLowerCase()}</h2>
        <p class="text-gray-600 leading-relaxed whitespace-pre-line">{category.editorial}</p>
      </div>
    </section>
  )}
</BaseLayout>
