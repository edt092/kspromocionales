---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Icon from '@/components/Icon.astro';
import { SITE } from '@/lib/site';
import { collectionPageSchema, breadcrumbListSchema } from '@/lib/schema';
import categories from '@data/categories.json';
import products from '@data/products.json';

const fallbackImage = '/images/products/_placeholder-ksp-co.jpg';
function countFor(catId: string) {
  return (products as any[]).filter((p) => p.categoryId === catId).length;
}

const catalogUrl = `${SITE.url}/categorias/`;
const jsonLd = [
  collectionPageSchema({
    name: 'Catálogo completo de productos promocionales',
    description: 'Todas las categorías de artículos publicitarios y regalos corporativos personalizados de KS Promocionales Colombia.',
    url: catalogUrl,
  }),
  breadcrumbListSchema([
    { name: 'Inicio', item: SITE.url },
    { name: 'Categorías', item: catalogUrl },
  ]),
];
---

<BaseLayout
  title="Catálogo completo de productos promocionales | KS Promocionales Colombia"
  description="Explora las categorías completas de artículos publicitarios y regalos corporativos personalizados: tecnología, drinkware, oficina, ropa, y más. Cotiza por WhatsApp."
  jsonLd={jsonLd}
>
  <section class="section-navy-deep relative pt-32 pb-16">
    <div class="container-ks relative z-10">
      <span class="section-label mb-4"><Icon name="layers" size={15} /> Catálogo</span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white max-w-2xl">
        Todas las categorías de productos promocionales
      </h1>
    </div>
  </section>

  <section class="py-14 lg:py-20">
    <div class="container-ks grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
      {(categories as any[]).map((cat, i) => (
        <a
          href={`/categorias/${cat.slug}/`}
          data-tilt
          data-tilt-max="5"
          class={`category-card-v2 group block reveal stagger-${(i % 6) + 1}`}
          style={`--stagger: ${(i % 6) * 50}ms`}
        >
          <div class="aspect-[4/3] w-full overflow-hidden bg-ks-navy-wash">
            <img
              src={cat.image || fallbackImage}
              alt={cat.name}
              loading={i < 4 ? 'eager' : 'lazy'}
              width="400"
              height="300"
              onerror={`this.onerror=null;this.src='${fallbackImage}'`}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-6">
            <h2 class="font-heading font-bold text-[#0A0A23] mb-1 leading-snug">{cat.name}</h2>
            <p class="text-xs text-gray-500">{countFor(cat.id)} referencias</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
