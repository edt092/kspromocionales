---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductCard from '@/components/ProductCard.astro';
import Icon from '@/components/Icon.astro';
import { productWhatsappUrl } from '@/lib/whatsapp';
import { SITE } from '@/lib/site';
import { getProductImage, getValidProductImages } from '@/lib/product-image';
import products from '@data/products.json';
import categories from '@data/categories.json';

export function getStaticPaths() {
  return (products as any[]).map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const category = (categories as any[]).find((c) => c.id === product.categoryId || c.slug === product.categoryId);
const related = (products as any[])
  .filter((p) => p.categoryId === product.categoryId && p.slug !== product.slug)
  .slice(0, 4);
const image = getProductImage(product.images);
const validImages = getValidProductImages(product.images);
const ctaUrl = productWhatsappUrl(product.name, product.whatsappMessage);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: product.name,
    description: product.description || product.shortDescription,
    image: validImages.length ? validImages : undefined,
    url: `${SITE.url}/productos/${product.slug}/`,
    brand: { '@type': 'Brand', name: SITE.name },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
      category && { '@type': 'ListItem', position: 2, name: category.name, item: `${SITE.url}/categorias/${category.slug}/` },
      { '@type': 'ListItem', position: 3, name: product.name, item: `${SITE.url}/productos/${product.slug}/` },
    ].filter(Boolean),
  },
];
---

<BaseLayout
  title={product.seoTitle || `${product.name} Personalizado | Colombia`}
  description={product.seoDescription || product.shortDescription || product.description}
  jsonLd={jsonLd}
>
  <div class="bg-gray-50 pt-28 pb-4">
    <div class="container-ks">
      <nav class="flex items-center gap-2 text-sm text-gray-600 flex-wrap">
        <a href="/" class="hover:text-ks-navy transition-colors">Inicio</a>
        <span>/</span>
        <a href="/categorias/" class="hover:text-ks-navy transition-colors">Categorías</a>
        {category && (
          <>
            <span>/</span>
            <a href={`/categorias/${category.slug}/`} class="hover:text-ks-navy transition-colors">{category.name}</a>
          </>
        )}
        <span>/</span>
        <span class="text-ks-navy font-medium">{product.name}</span>
      </nav>
    </div>
  </div>

  <section class="py-10 lg:py-16">
    <div class="container-ks grid lg:grid-cols-2 gap-12">
      <div class="aspect-product rounded-2xl overflow-hidden bg-ks-navy-wash">
        <img src={image} alt={product.name} class="w-full h-full object-cover" width="600" height="600" />
      </div>

      <div>
        {category && (
          <a href={`/categorias/${category.slug}/`} class="section-label mb-3">
            <Icon name="layers" size={14} /> {category.name}
          </a>
        )}
        <h1 class="text-3xl sm:text-4xl font-heading font-bold text-[#0A0A23] mb-4 leading-tight">{product.name}</h1>
        {product.shortDescription && <p class="text-lg text-gray-600 mb-8 leading-relaxed">{product.shortDescription}</p>}

        <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp pulse-whatsapp w-full sm:w-auto justify-center mb-8">
          <Icon name="message-circle" size={18} /> Cotizar por WhatsApp
        </a>

        {product.features?.length > 0 && (
          <div class="mb-8">
            <h2 class="font-heading font-bold text-[#0A0A23] mb-3">Características</h2>
            <ul class="space-y-2.5">
              {product.features.map((f: string) => (
                <li class="flex items-start gap-2.5 text-gray-600 text-sm">
                  <Icon name="check-circle" size={16} class="text-ks-orange shrink-0 mt-0.5" />
                  {f}
                </li>
              ))}
            </ul>
          </div>
        )}

        {product.useCases?.length > 0 && (
          <div class="glass-card-light border border-gray-100 rounded-xl p-5 bg-ks-navy-ghost">
            <h2 class="font-heading font-bold text-[#0A0A23] mb-3 text-sm uppercase tracking-wide">Ideal para</h2>
            <ul class="space-y-2">
              {product.useCases.map((u: string) => (
                <li class="text-sm text-gray-600 flex items-start gap-2.5">
                  <Icon name="star" size={14} class="text-ks-navy shrink-0 mt-0.5" />
                  {u}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>

    {product.story && (
      <div class="container-ks max-w-3xl mt-16 pt-12 border-t border-gray-100">
        <h2 class="font-heading font-bold text-2xl text-[#0A0A23] mb-4">Sobre este producto</h2>
        <p class="text-gray-600 leading-relaxed whitespace-pre-line">{product.story}</p>
      </div>
    )}
  </section>

  {related.length > 0 && (
    <section class="py-16 lg:py-20 bg-ks-navy-ghost">
      <div class="container-ks">
        <h2 class="heading-underline text-2xl sm:text-3xl font-heading font-bold text-[#0A0A23] mb-10">
          También te puede interesar
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
          {related.map((p) => <ProductCard product={p} />)}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
