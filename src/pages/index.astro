---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero3D from '@/components/Hero3D.astro';
import BenefitsBar from '@/components/BenefitsBar.astro';
import CategoryBlueprintGrid from '@/components/CategoryBlueprintGrid.astro';
import ScaleCustomizationSection from '@/components/ScaleCustomizationSection.astro';
import BestsellersSection from '@/components/BestsellersSection.astro';
import FaqSection from '@/components/FaqSection.astro';
import FinalCta from '@/components/FinalCta.astro';
import { organizationSchema, websiteSchema } from '@/lib/schema';

const jsonLd = [organizationSchema(), websiteSchema()];
---

<BaseLayout
  title="Productos Promocionales en Colombia | Regalos Corporativos con Logo — KS Promocionales"
  description="Artículos publicitarios y regalos corporativos personalizados con tu logo para empresas en toda Colombia. Catálogo con más de 2.000 referencias, cotización directa por WhatsApp. Operación online desde Girón, área metropolitana de Bucaramanga."
  jsonLd={jsonLd}
>
  <Hero3D />
  <BenefitsBar />
  <CategoryBlueprintGrid />
  <ScaleCustomizationSection />
  <BestsellersSection />
  <FaqSection />
  <FinalCta />
</BaseLayout>
