---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Icon from '@/components/Icon.astro';
import { SITE } from '@/lib/site';
import { cityWhatsappUrl } from '@/lib/whatsapp';
import { breadcrumbListSchema } from '@/lib/schema';
import categories from '@data/categories.json';

const ctaUrl = cityWhatsappUrl(SITE.primaryCity);
const categoryOptions = (categories as any[]).map((c) => c.name);

const jsonLd = breadcrumbListSchema([
  { name: 'Inicio', item: SITE.url },
  { name: 'Contacto', item: `${SITE.url}/contacto/` },
]);
---

<BaseLayout
  title="Contacto | KS Promocionales Colombia"
  description={`Contáctanos por WhatsApp al ${SITE.whatsappDisplay} para cotizar productos promocionales en ${SITE.primaryCity} y toda Colombia.`}
  jsonLd={jsonLd}
>
  <section class="section-navy-deep relative pt-32 pb-24">
    <div class="container-ks relative z-10 max-w-2xl text-center mx-auto">
      <span class="section-label justify-center mb-4"><Icon name="message-circle" size={15} /> Contacto</span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-6">
        Hablemos por WhatsApp
      </h1>
      <p class="text-white/70 text-lg mb-10">
        Es el canal más rápido para cotizar: cuéntanos el producto, la cantidad aproximada y tu
        ciudad, y te respondemos con una propuesta.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 max-w-lg mx-auto">
        <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="glass-card p-6 text-left hover:!border-ks-orange/40">
          <Icon name="message-circle" size={22} class="text-ks-orange mb-3" />
          <p class="font-heading font-bold text-white text-sm mb-1">WhatsApp</p>
          <p class="text-white/60 text-xs">{SITE.whatsappDisplay}</p>
        </a>
        <a href={`tel:+${SITE.whatsappNumber}`} class="glass-card p-6 text-left hover:!border-ks-orange/40">
          <Icon name="phone" size={22} class="text-ks-orange mb-3" />
          <p class="font-heading font-bold text-white text-sm mb-1">Llamada</p>
          <p class="text-white/60 text-xs">{SITE.whatsappDisplay}</p>
        </a>
      </div>

      <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn-hero-primary mt-10">
        <Icon name="message-circle" size={18} /> Cotizar por WhatsApp
      </a>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="container-ks max-w-2xl mx-auto text-center">
      <div class="flex items-center justify-center gap-2 text-gray-600">
        <Icon name="map-pin" size={18} class="text-ks-navy" />
        <span>{SITE.operatingBase} — operación online, sin atención al público. Envíos a toda Colombia.</span>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-ks-navy-ghost">
    <div class="container-ks max-w-2xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="heading-underline text-2xl sm:text-3xl font-heading font-bold text-[#0A0A23] mb-4">
          ¿Prefieres enviarnos un briefing por escrito?
        </h2>
        <p class="text-gray-600">
          Útil si tu área de compras necesita dejar la solicitud registrada. Te respondemos por correo o WhatsApp con la propuesta.
        </p>
      </div>

      <form
        name="briefing-contacto"
        method="POST"
        action="/gracias/"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="card-surface p-6 sm:p-8 grid grid-cols-1 sm:grid-cols-2 gap-5"
      >
        <input type="hidden" name="form-name" value="briefing-contacto" />
        <p class="hidden">
          <label>No llenar este campo: <input name="bot-field" /></label>
        </p>

        <div class="sm:col-span-1">
          <label for="nombre" class="block text-sm font-medium text-[#0A0A23] mb-1.5">Nombre</label>
          <input id="nombre" name="nombre" type="text" required class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ks-orange/40" />
        </div>
        <div class="sm:col-span-1">
          <label for="empresa" class="block text-sm font-medium text-[#0A0A23] mb-1.5">Empresa</label>
          <input id="empresa" name="empresa" type="text" class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ks-orange/40" />
        </div>
        <div class="sm:col-span-1">
          <label for="correo" class="block text-sm font-medium text-[#0A0A23] mb-1.5">Correo corporativo</label>
          <input id="correo" name="correo" type="email" required class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ks-orange/40" />
        </div>
        <div class="sm:col-span-1">
          <label for="telefono" class="block text-sm font-medium text-[#0A0A23] mb-1.5">Teléfono <span class="text-gray-400 font-normal">(opcional)</span></label>
          <input id="telefono" name="telefono" type="tel" autocomplete="tel" class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ks-orange/40" />
        </div>
        <div class="sm:col-span-1">
          <label for="categoria" class="block text-sm font-medium text-[#0A0A23] mb-1.5">Producto o categoría</label>
          <select id="categoria" name="categoria" class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ks-orange/40 bg-white">
            <option value="">Selecciona una categoría (opcional)</option>
            {categoryOptions.map((name) => <option value={name}>{name}</option>)}
            <option value="No estoy seguro">No estoy seguro / varias categorías</option>
          </select>
        </div>
        <div class="sm:col-span-1">
          <label for="cantidad" class="block text-sm font-medium text-[#0A0A23] mb-1.5">Cantidad aproximada</label>
          <input id="cantidad" name="cantidad" type="text" placeholder="Ej: 100, o 50-100" class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ks-orange/40" />
        </div>
        <div class="sm:col-span-1">
          <label for="ciudad" class="block text-sm font-medium text-[#0A0A23] mb-1.5">Ciudad o departamento de entrega</label>
          <input id="ciudad" name="ciudad" type="text" class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ks-orange/40" />
        </div>
        <div class="sm:col-span-1">
          <label for="fecha" class="block text-sm font-medium text-[#0A0A23] mb-1.5">Fecha estimada <span class="text-gray-400 font-normal">(opcional)</span></label>
          <input id="fecha" name="fecha" type="date" class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ks-orange/40" />
        </div>
        <div class="sm:col-span-2">
          <label for="mensaje" class="block text-sm font-medium text-[#0A0A23] mb-1.5">Cuéntanos qué necesitas</label>
          <textarea id="mensaje" name="mensaje" rows="4" required placeholder="Detalles adicionales sobre tu producto, evento o marca" class="w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-ks-orange/40"></textarea>
        </div>

        <div class="sm:col-span-2">
          <label for="privacidad" class="flex items-start gap-2.5 text-sm text-gray-600">
            <input id="privacidad" name="privacidad" type="checkbox" required aria-required="true" class="mt-0.5 rounded border-gray-300 text-ks-navy focus:ring-ks-orange/40" />
            <span>
              He leído y acepto la <a href="/politica-de-privacidad/" class="text-ks-navy font-medium hover:underline">política de privacidad</a>.
            </span>
          </label>
        </div>

        <div class="sm:col-span-2">
          <button type="submit" class="btn-primary w-full sm:w-auto justify-center">
            <Icon name="message-circle" size={18} /> Enviar briefing
          </button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
