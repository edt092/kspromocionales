---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Icon from '@/components/Icon.astro';
import ProductCard from '@/components/ProductCard.astro';
import FaqSection from '@/components/FaqSection.astro';
import { SITE } from '@/lib/site';
import { cityWhatsappUrl } from '@/lib/whatsapp';
import { breadcrumbListSchema } from '@/lib/schema';
import products from '@data/products.json';
import categories from '@data/categories.json';

const ctaUrl = cityWhatsappUrl(SITE.primaryCity);
const list = (products as any[]).filter((p) => p.bestseller).slice(0, 8);
const shown = list.length ? list : (products as any[]).slice(8, 16);
const topCategories = (categories as any[]).slice(0, 6);

const breadcrumbJsonLd = breadcrumbListSchema([
  { name: 'Inicio', item: SITE.url },
  { name: 'Artículos Promocionales', item: `${SITE.url}/articulos-promocionales/` },
]);

const faqs = [
  { question: '¿Qué son los artículos promocionales?', answer: 'Objetos de uso cotidiano —lapiceros, mugs, memorias USB, bolsos— personalizados con el logo de tu empresa, entregados como estrategia de marketing de bajo costo por impacto.' },
  { question: '¿Cuál es la diferencia con un regalo corporativo?', answer: 'Un artículo promocional suele entregarse en volumen (ferias, activaciones) mientras el regalo corporativo suele ser más selectivo. El catálogo es el mismo; cambia el uso que le des.' },
  { question: '¿Puedo pedir varias referencias en un mismo pedido?', answer: 'Sí, muchas empresas combinan 2-3 artículos distintos para armar un kit. Cuéntanos tu idea por WhatsApp y te ayudamos a definirlo.' },
];
---

<BaseLayout
  title="Artículos Promocionales Personalizados en Colombia | KS Promocionales"
  description="Lapiceros, mugs, memorias USB, bolsos y más artículos promocionales personalizados con tu logo. Cotiza por WhatsApp, envíos a toda Colombia desde Bucaramanga."
  jsonLd={breadcrumbJsonLd}
>
  <section class="section-navy relative overflow-hidden py-20 lg:py-28">
    <div class="container-ks relative z-10 max-w-3xl">
      <span class="section-label mb-4"><Icon name="package" size={15} /> Artículos Promocionales</span>
      <h1 class="text-4xl sm:text-5xl font-heading font-bold text-white mb-6 text-balance">
        El artículo correcto, en la cantidad correcta, con tu logo
      </h1>
      <p class="text-white/75 text-lg mb-9">
        Miles de referencias organizadas por categoría para que tu campaña no dependa de
        adivinar: tecnología, drinkware, oficina, ropa y mucho más.
      </p>
      <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn-hero-primary">
        <Icon name="message-circle" size={18} /> Cotizar por WhatsApp
      </a>
    </div>
  </section>

  <section class="py-14 bg-white border-b border-gray-100">
    <div class="container-ks flex flex-wrap gap-3 justify-center">
      {topCategories.map((cat: any) => (
        <a href={`/categorias/${cat.slug}/`} class="badge-tag inline-flex items-center px-4 py-2 text-sm font-medium bg-ks-navy-wash text-ks-navy border border-ks-navy/10 rounded-full hover:bg-ks-navy hover:text-white transition-colors">
          {cat.name}
        </a>
      ))}
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-ks-navy-ghost">
    <div class="container-ks">
      <h2 class="heading-underline text-2xl sm:text-3xl font-heading font-bold text-[#0A0A23] mb-10">
        Los artículos más pedidos
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
        {shown.map((p: any, i: number) => (
          <div class={`reveal stagger-${(i % 6) + 1}`} style={`--stagger: ${(i % 6) * 60}ms`}>
            <ProductCard product={p} eager={i < 4} />
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/categorias/" class="btn-primary">Ver las 37 categorías <Icon name="arrow-right" size={16} /></a>
      </div>
    </div>
  </section>

  <FaqSection items={faqs} title="Preguntas frecuentes sobre artículos promocionales" />
</BaseLayout>
