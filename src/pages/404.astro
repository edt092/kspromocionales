---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Icon from '@/components/Icon.astro';
import { SITE } from '@/lib/site';
import { cityWhatsappUrl } from '@/lib/whatsapp';

const ctaUrl = cityWhatsappUrl(SITE.primaryCity);
---

<BaseLayout
  title="Página no encontrada | KS Promocionales Colombia"
  description="La página que buscas no existe o fue movida."
  noindex
>
  <section class="section-navy-deep relative min-h-[70vh] flex items-center pt-24">
    <div class="container-ks relative z-10 text-center max-w-xl mx-auto">
      <p class="text-8xl font-heading font-extrabold text-white/10 mb-4">404</p>
      <h1 class="text-2xl sm:text-3xl font-heading font-bold text-white mb-4">
        No encontramos esta página
      </h1>
      <p class="text-white/60 mb-9">
        Puede que el enlace haya cambiado. Explora el catálogo o escríbenos y te ayudamos a encontrar lo que buscas.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/categorias/" class="btn-primary">
          <Icon name="layers" size={16} /> Ver catálogo
        </a>
        <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
          <Icon name="message-circle" size={16} /> Escribir por WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
