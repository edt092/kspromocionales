---
import Icon from '@/components/Icon.astro';
import { SITE } from '@/lib/site';
import { cityWhatsappUrl } from '@/lib/whatsapp';

const ctaUrl = cityWhatsappUrl(SITE.primaryCity);
---

<section class="section-navy relative py-24 lg:py-28 overflow-hidden">
  <div class="absolute inset-0 grid-pattern pointer-events-none"></div>
  <div class="container-ks relative z-10 text-center max-w-2xl mx-auto reveal">
    <h2 class="text-3xl sm:text-4xl font-heading font-bold mb-5 text-balance">
      ¿Listo para llevar tu marca a donde tu cliente la use todos los días?
    </h2>
    <p class="text-white/70 text-lg mb-9">
      Cuéntanos qué necesitas y te respondemos por WhatsApp con opciones reales de tu presupuesto.
    </p>
    <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn-hero-primary">
      <Icon name="message-circle" size={18} /> Cotizar Ahora
    </a>
  </div>
</section>
