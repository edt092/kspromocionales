---
import Icon from '@/components/Icon.astro';
import { SITE } from '@/lib/site';
import { cityWhatsappUrl } from '@/lib/whatsapp';

const ctaUrl = cityWhatsappUrl(SITE.primaryCity);
---

<section id="hero" class="section-navy-deep relative min-h-screen overflow-hidden">
  <!-- Grid de fondo "blueprint" — se traslada a 0.3x la velocidad del scroll (ver script) -->
  <div id="hero-grid-bg" class="absolute inset-0 grid-pattern opacity-30 pointer-events-none" style="background-size: 56px 56px;"></div>
  <div class="absolute inset-0 noise-overlay pointer-events-none"></div>

  <div class="container-ks relative z-10 flex items-center min-h-screen pt-36 pb-24">
    <!-- Tipografía de alto contraste -->
    <div id="hero-copy" class="max-w-2xl">
      <span class="section-label mb-5">
        <Icon name="sparkles" size={15} /> {SITE.primaryCity} y Colombia
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-white leading-[1.05] mb-6 text-balance">
        Productos promocionales que tu marca
        <span class="text-gradient-orange">sí se hace notar</span>
      </h1>
      <p class="text-lg text-white/70 max-w-xl mb-9 leading-relaxed">
        Artículos publicitarios y regalos corporativos personalizados con tu logo,
        con cotización directa por WhatsApp. Catálogo curado por categoría, sin vueltas,
        con envíos a {SITE.primaryCity} y toda Colombia.
      </p>
      <div class="flex flex-wrap gap-4 mb-12">
        <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn-hero-primary">
          <Icon name="message-circle" size={18} /> Cotizar por WhatsApp
        </a>
        <a href="/categorias/" class="btn-hero-ghost">
          Ver catálogo <Icon name="arrow-right" size={18} />
        </a>
      </div>
      <div class="flex flex-wrap gap-x-10 gap-y-4">
        <div>
          <p class="text-2xl font-heading font-bold text-white">2.000+</p>
          <p class="text-xs uppercase tracking-wide text-white/50">Referencias en catálogo</p>
        </div>
        <div>
          <p class="text-2xl font-heading font-bold text-white">37</p>
          <p class="text-xs uppercase tracking-wide text-white/50">Categorías de producto</p>
        </div>
        <div>
          <p class="text-2xl font-heading font-bold text-white">100%</p>
          <p class="text-xs uppercase tracking-wide text-white/50">Cotización por WhatsApp</p>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 text-white/40 text-xs uppercase tracking-widest">
    <span>Desliza</span>
    <span class="w-px h-8 bg-gradient-to-b from-white/40 to-transparent"></span>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const heroSection = document.getElementById('hero');
  const heroGridBg = document.getElementById('hero-grid-bg');

  // El grid de fondo se mueve a 0.3x la velocidad del scroll (profundidad).
  if (heroSection && heroGridBg) {
    gsap.to(heroGridBg, {
      backgroundPosition: '0px 300px',
      ease: 'none',
      scrollTrigger: { trigger: heroSection, start: 'top top', end: 'bottom top', scrub: 0.3 },
    });
  }
</script>
