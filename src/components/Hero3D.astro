---
import Icon from '@/components/Icon.astro';
import { SITE } from '@/lib/site';
import { cityWhatsappUrl } from '@/lib/whatsapp';

const ctaUrl = cityWhatsappUrl(SITE.primaryCity);
---

<section id="hero" class="section-navy-deep relative min-h-screen overflow-hidden">
  <!-- Grid de fondo "blueprint" — se traslada a 0.3x la velocidad del scroll (ver script) -->
  <div id="hero-grid-bg" class="absolute inset-0 grid-pattern opacity-30 pointer-events-none" style="background-size: 56px 56px;"></div>
  <div class="absolute inset-0 noise-overlay pointer-events-none"></div>

  <div class="container-ks relative z-10 grid lg:grid-cols-[1.05fr,1fr] gap-10 items-center min-h-screen pt-36 pb-24">
    <!-- Columna izquierda: tipografía de alto contraste -->
    <div id="hero-copy">
      <span class="section-label mb-5">
        <Icon name="sparkles" size={15} /> Showroom 3D · {SITE.primaryCity} y Colombia
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-extrabold text-white leading-[1.05] mb-6 text-balance">
        Productos promocionales que tu marca
        <span class="text-gradient-orange">sí se hace notar</span>
      </h1>
      <p class="text-lg text-white/70 max-w-xl mb-9 leading-relaxed">
        Artículos publicitarios y regalos corporativos personalizados con tu logo,
        con cotización directa por WhatsApp. Catálogo curado por categoría, sin vueltas,
        con envíos a {SITE.primaryCity} y toda Colombia.
      </p>
      <div class="flex flex-wrap gap-4 mb-12">
        <a href={ctaUrl} target="_blank" rel="noopener noreferrer" class="btn-hero-primary">
          <Icon name="message-circle" size={18} /> Cotizar por WhatsApp
        </a>
        <a href="/categorias/" class="btn-hero-ghost">
          Ver catálogo <Icon name="arrow-right" size={18} />
        </a>
      </div>
      <div class="flex flex-wrap gap-x-10 gap-y-4">
        <div>
          <p class="text-2xl font-heading font-bold text-white">2.000+</p>
          <p class="text-xs uppercase tracking-wide text-white/50">Referencias en catálogo</p>
        </div>
        <div>
          <p class="text-2xl font-heading font-bold text-white">37</p>
          <p class="text-xs uppercase tracking-wide text-white/50">Categorías de producto</p>
        </div>
        <div>
          <p class="text-2xl font-heading font-bold text-white">100%</p>
          <p class="text-xs uppercase tracking-wide text-white/50">Cotización por WhatsApp</p>
        </div>
      </div>
    </div>

    <!-- Columna derecha: canvas WebGL -->
    <div class="relative h-[380px] sm:h-[460px] lg:h-[640px]">
      <canvas id="hero-canvas" class="absolute inset-0 w-full h-full" aria-hidden="true"></canvas>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 text-white/40 text-xs uppercase tracking-widest">
    <span>Desliza</span>
    <span class="w-px h-8 bg-gradient-to-b from-white/40 to-transparent"></span>
  </div>
</section>

<script>
  // Imports nombrados (no `import * as THREE`) para que Rollup pueda hacer
  // tree-shaking real del resto de three.js — el paquete completo pesa
  // varios MB y solo usamos un puñado de clases.
  import {
    Scene, PerspectiveCamera, WebGLRenderer, DirectionalLight, AmbientLight,
    PointLight, Group, Box3, Vector3, Clock,
  } from 'three';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement | null;
  const heroSection = document.getElementById('hero');
  const heroGridBg = document.getElementById('hero-grid-bg');
  if (!canvas || !heroSection) {
    // Sin WebGL / sin hero en esta página (fallback silencioso, no rompe el resto del sitio).
  } else {
    const container = canvas.parentElement as HTMLElement;

    // ── Escena base ──────────────────────────────────────────────────────
    const scene = new Scene();
    const camera = new PerspectiveCamera(42, container.clientWidth / container.clientHeight, 0.1, 100);
    camera.position.set(0, 0.2, 6);

    const renderer = new WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(container.clientWidth, container.clientHeight);

    // Iluminación mínima: una luz direccional (define volumen) + ambiente (evita negros puros).
    const key = new DirectionalLight(0xffffff, 2.2);
    key.position.set(3, 4, 5);
    scene.add(key);
    scene.add(new AmbientLight(0x4a5cc9, 1.1));
    const rim = new PointLight(0xf5a520, 6, 12);
    rim.position.set(-3, -1, 2);
    scene.add(rim);

    // ── Los 3 objetos flotantes: modelos reales exportados desde Blender
    // (tomatodo, portallavero, bolígrafo) — reemplazan las geometrías
    // primitivas (cilindro/icosaedro/caja) que se usaban antes. Cada modelo
    // se carga en un Group "cascarón" que se centra y escala a una altura
    // objetivo, para poder animarlo igual que a las primitivas anteriores.
    const bottle = new Group();
    bottle.position.set(-1.5, 0.6, 0);

    const gadget = new Group();
    gadget.position.set(1.4, 1.1, -0.6);

    const pen = new Group();
    pen.position.set(0.9, -0.9, 0.4);
    pen.rotation.set(0.15, -0.4, 0.08);

    const rig = new Group();
    rig.add(bottle, gadget, pen);
    scene.add(rig);

    const floaters = [
      { obj: bottle, speed: 0.6, offset: 0 },
      { obj: gadget, speed: 0.8, offset: 2.1 },
      { obj: pen, speed: 0.5, offset: 4.2 },
    ];

    // Centra el modelo en su propio bounding box y lo escala a targetHeight,
    // envuelto en un Group para que el padre (bottle/gadget/pen) conserve su
    // pivote en el origen sin importar el offset del modelo exportado.
    function normalizeModel(root: import('three').Object3D, targetHeight: number) {
      const box = new Box3().setFromObject(root);
      const size = new Vector3();
      box.getSize(size);
      const center = new Vector3();
      box.getCenter(center);
      root.position.sub(center);
      const wrapper = new Group();
      wrapper.scale.setScalar(targetHeight / (size.y || 1));
      wrapper.add(root);
      return wrapper;
    }

    const loader = new GLTFLoader();
    const modelTargets: Array<[string, Group, number]> = [
      ['/models/tomatodo.glb', bottle, 1.9],
      ['/models/portallavero.glb', gadget, 1.3],
      ['/models/boligrafo.glb', pen, 1.7],
    ];
    for (const [url, parent, targetHeight] of modelTargets) {
      loader.load(url, (gltf) => {
        parent.add(normalizeModel(gltf.scene, targetHeight));
      });
    }

    // ── Parallax por mouse: la perspectiva de una escena 3D depende del
    // ángulo desde el que "miramos" la cámara. Convertimos la posición del
    // mouse en coordenadas normalizadas de dispositivo (NDC, rango -1..1,
    // origen en el centro de la pantalla) y usamos ese valor como el ÁNGULO
    // objetivo de rotación del grupo, escalado por un máximo pequeño
    // (maxTilt) para que el efecto sea sutil. En vez de saltar directo al
    // valor objetivo, interpolamos linealmente (lerp) hacia él cada frame:
    // rotation += (target - rotation) * factor — esto es un filtro paso-bajo
    // discreto que simula inercia/amortiguación sin resortes físicos reales.
    const pointer = { x: 0, y: 0 };
    const maxTilt = 0.22; // radianes (~12.6°)
    window.addEventListener(
      'pointermove',
      (e) => {
        pointer.x = (e.clientX / window.innerWidth) * 2 - 1;
        pointer.y = (e.clientY / window.innerHeight) * 2 - 1;
      },
      { passive: true }
    );

    // ── Dispersión al hacer scroll (GSAP ScrollTrigger, scrubbed) ─────────
    // "scrub: true" ata el progreso de la timeline 1:1 al scroll (no es una
    // animación con tiempo propio); por eso animamos con duration:1 "unidad"
    // y dejamos que el progreso del ScrollTrigger controle el avance real.
    const scatterTl = gsap.timeline({
      scrollTrigger: { trigger: heroSection, start: 'top top', end: 'bottom top', scrub: 0.6 },
    });
    scatterTl
      .to(bottle.position, { x: -4.5, y: 2.2, duration: 1 }, 0)
      .to(bottle.rotation, { y: Math.PI * 1.4, duration: 1 }, 0)
      .to(gadget.position, { x: 4.2, y: -2.6, z: -2, duration: 1 }, 0)
      .to(gadget.rotation, { x: Math.PI, y: Math.PI * 0.8, duration: 1 }, 0)
      .to(pen.position, { x: 3, y: 3, duration: 1 }, 0)
      .to(pen.rotation, { y: Math.PI * -1.2, duration: 1 }, 0)
      .to(container, { opacity: 0, duration: 1 }, 0.15);

    // El grid de fondo se mueve a 0.3x la velocidad del scroll (profundidad).
    if (heroGridBg) {
      gsap.to(heroGridBg, {
        backgroundPosition: '0px 300px',
        ease: 'none',
        scrollTrigger: { trigger: heroSection, start: 'top top', end: 'bottom top', scrub: 0.3 },
      });
    }

    // ── Loop único de render (rAF) ─────────────────────────────────────
    const clock = new Clock();
    let frameId: number;
    function tick() {
      const t = clock.getElapsedTime();

      for (const f of floaters) {
        f.obj.position.y += Math.sin(t * f.speed + f.offset) * 0.0025;
        f.obj.rotation.y += 0.0028 * f.speed;
      }

      rig.rotation.y += (pointer.x * maxTilt - rig.rotation.y) * 0.04;
      rig.rotation.x += (-pointer.y * maxTilt * 0.6 - rig.rotation.x) * 0.04;

      renderer.render(scene, camera);
      frameId = requestAnimationFrame(tick);
    }
    tick();

    // ── Resize ──────────────────────────────────────────────────────────
    const onResize = () => {
      const w = container.clientWidth;
      const h = container.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    };
    window.addEventListener('resize', onResize);

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(frameId);
      renderer.dispose();
      window.removeEventListener('resize', onResize);
    });
  }
</script>
